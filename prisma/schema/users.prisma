model User {
  id       String     @id @default(uuid())
  name     String
  email    String     @unique
  password String
  role     UserRole   @default(CUSTOMER)
  status   UserStatus @default(ACTIVE)
  phone    String?
  address  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  //? relationship with other tables
  reviews Reviews[]
  gearItems GearItems[]
  orders RentalOrders[]


  // @@map("users")
}
